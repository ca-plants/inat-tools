{
    "type": "module",
    "bin": {
        "int-build": "scripts/int-build.js"
    },
    "scripts": {
        "ava": "ava tests/js/test*.js",
        "check": "npm run tsc && npm run eslint && npm run ava && npm run jest",
        "dev-build": "concurrently -k \"node scripts/int-build.js\" \"npm run dev-parcel\"",
        "dev-parcel": "parcel watch --dist-dir public",
        "eslint": "eslint app tests",
        "jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/jest",
        "prettier": "prettier -l .",
        "tsc": "tsc"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@observablehq/plot": "^0.6.16",
        "@types/d3": "^7.4.3",
        "@types/geojson": "^7946.0.16",
        "@types/jest": "^30.0.0",
        "@types/jstoxml": "^2.0.4",
        "@types/leaflet": "^1.9.16",
        "@types/which-polygon": "^2.2.5",
        "ava": "^6.4.1",
        "concurrently": "^9.2.1",
        "eslint": "^10.0.0",
        "globals": "^17.3.0",
        "jest": "^30.2.0",
        "jstoxml": "^5.0.2",
        "leaflet": "^1.9.4",
        "parcel": "^2.16.3",
        "pkce-challenge": "^5.0.1",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "which-polygon": "^2.2.1"
    },
    "dependencies": {
        "@metalsmith/in-place": "^5.0.0",
        "@metalsmith/layouts": "^2.7.0",
        "@turf/turf": "^7.2.0",
        "commander": "^14.0.2",
        "jstransformer-marked": "^1.4.0",
        "jstransformer-nunjucks": "^1.2.0",
        "metalsmith": "^2.6.3"
    },
    "targets": {
        "default": {
            "source": [
                "ms/index.html",
                "ms/obsdetail.html",
                "ms/api.html",
                "ms/favicon.ico",
                "ms/img/**"
            ]
        }
    }
}
