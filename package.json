{
    "type": "module",
    "scripts": {
        "ava": "ava tests/js/test*.js",
        "build": "npm run build-js && npm run build-eleventy",
        "build-js": "npx rollup --config ./config/config-rollup.js",
        "build-eleventy": "npx @11ty/eleventy --config config/config-eleventy.js",
        "build-eleventy-dev": "npx @11ty/eleventy --config config/config-eleventy.js --watch",
        "build-js-dev": "npx rollup --config ./config/config-rollup-dev.js",
        "check": "npm run tsc && npm run eslint && npm run ava && npm run jest",
        "dev": "rm -rf public && concurrently -k \"npx rollup --config ./config/config-rollup-dev.js --watch\" \"npm run build-eleventy-dev\"",
        "eslint": "eslint app tests",
        "jest": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/jest",
        "prettier": "prettier -l .",
        "tsc": "tsc"
    },
    "devDependencies": {
        "@11ty/eleventy": "^3.1.5",
        "@eslint/js": "^10.0.1",
        "@htmltools/hdom": "^0.1.1",
        "@observablehq/plot": "^0.6.16",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@rollup/plugin-terser": "^1.0.0",
        "@turf/turf": "^7.3.5",
        "@types/d3": "^7.4.3",
        "@types/geojson": "^7946.0.16",
        "@types/jstoxml": "^5.0.0",
        "@types/leaflet": "^1.9.21",
        "@types/which-polygon": "^2.2.5",
        "ava": "^6.4.1",
        "concurrently": "^9.2.1",
        "d3-dsv": "^3.0.1",
        "eslint": "^10.3.0",
        "globals": "^17.6.0",
        "jest": "^30.3.0",
        "jstoxml": "^7.0.1",
        "leaflet": "^1.9.4",
        "pkce-challenge": "^6.0.0",
        "prettier": "^3.8.1",
        "rollup": "^4.60.3",
        "typescript": "^6.0.3",
        "which-polygon": "^2.2.1"
    }
}
